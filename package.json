{
  "name": "cheatsheet-generate",
  "private": true,
  "version": "2.0.3",
  "description": "AI-based cheatsheet generator and downloader",
  "scripts": {
    "build": "npm run build:cheat:all && npm run build:nav",
    "build:nav": "node scripts/generate-nav.js && node scripts/inject-favicon.js",
    "build:cheat:all": "node ./cheatsheet-html-maker/index.js --input ./cheatsheets/**/*.md",
    "meta:migrate": "node scripts/migrate-meta.js",
    "meta:validate": "node scripts/validate-meta.js",
    "meta:inject": "node scripts/inject-meta-into-html.js",
    "fav:inject": "node scripts/inject-favicon.js",
    "watch": "node scripts/watch.js",
    "workflow": "node scripts/workflow.js",
    "release": "npx -y standard-version",
    "changelog": "npx -y standard-version",
    "update-skills": "node scripts/update-skills.js",
    "preview": "npx -y live-server@1.2.2 . --port=36715"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "canvas": "^3.2.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.5",
    "he": "^1.2.0",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.4",
    "js-yaml": "^4.1.1",
    "node-fetch": "^2.6.9",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=16"
  }
}
